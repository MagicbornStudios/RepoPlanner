{
  "name": "repo-planner",
  "version": "0.1.0",
  "private": false,
  "engines": {
    "node": ">=22.0.0"
  },
  "description": "Embeddable planning cockpit, parsing helpers, and CLI entrypoint for roadmap/state/task-registry loops.",
  "repository": {
    "type": "git",
    "url": "https://github.com/MagicbornStudios/RepoPlanner.git"
  },
  "homepage": "https://github.com/MagicbornStudios/RepoPlanner",
  "bugs": {
    "url": "https://github.com/MagicbornStudios/RepoPlanner/issues"
  },
  "keywords": [
    "planning",
    "roadmap",
    "task-registry",
    "cli",
    "nextjs",
    "workflow"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    ".planning",
    "api",
    "components",
    "lib",
    "scripts",
    "types",
    "cockpit-host-context.ts",
    "host.tsx",
    "index.tsx",
    "INSTALL.md",
    "README.md",
    "planning-pack.tsx",
    "planning.css",
    "STYLING.md",
    "tsconfig.json"
  ],
  "bin": {
    "repo-planner": "./scripts/loop-cli.mjs"
  },
  "dependencies": {
    "fast-xml-parser": "^5.5.9",
    "jszip": "^3.10.1"
  },
  "exports": {
    ".": "./index.tsx",
    "./host": "./host.tsx",
    "./cockpit-data": "./lib/planning-cockpit-data-source.ts",
    "./planning-pack": "./planning-pack.tsx",
    "./planning.css": "./planning.css",
    "./workspace-storage": "./lib/workspace-storage.ts",
    "./cockpit-host-context": "./cockpit-host-context.ts",
    "./embed-builtin-packs-build": "./scripts/lib/embed-builtin-packs-build.mjs",
    "./api/planning-state/route": "./api/planning-state/route.ts",
    "./api/planning-metrics/route": "./api/planning-metrics/route.ts",
    "./api/planning-roadmap/route": "./api/planning-roadmap/route.ts",
    "./api/planning-reports/latest/route": "./api/planning-reports/latest/route.ts",
    "./api/planning-cli/run/route": "./api/planning-cli/run/route.ts",
    "./api/planning-edits/apply/route": "./api/planning-edits/apply/route.ts",
    "./api/test-reports/unit/route": "./api/test-reports/unit/route.ts",
    "./lib/planning-workflow.mjs": {
      "types": "./lib/planning-workflow.mjs.d.ts",
      "default": "./lib/planning-workflow.mjs"
    },
    "./lib/planning-parse-core.mjs": {
      "types": "./lib/planning-parse-core.mjs.d.ts",
      "default": "./lib/planning-parse-core.mjs"
    }
  },
  "peerDependencies": {
    "@base-ui/react": ">=1",
    "next": ">=14",
    "react": ">=18",
    "react-dom": ">=18",
    "lucide-react": "*",
    "recharts": "*",
    "react-markdown": "*",
    "zod": "*",
    "@assistant-ui/react": "*",
    "@assistant-ui/react-ui": "*",
    "motion": "*"
  },
  "peerDependenciesMeta": {
    "@assistant-ui/react": { "optional": true },
    "@assistant-ui/react-ui": { "optional": true },
    "motion": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "~19.2.8",
    "@types/react-dom": "~19.2.3",
    "react": "~19.2.3",
    "react-dom": "~19.2.3",
    "lucide-react": "^0.562.0",
    "recharts": "^2.15.4",
    "react-markdown": "^10.1.0",
    "zod": "^3.23.0",
    "motion": "^12.34.4",
    "@assistant-ui/react": "^0.12.0",
    "@assistant-ui/react-ui": "^0.2.0",
    "diff": "^5.2.0",
    "gray-matter": "^4.0.3",
    "next": "^14.2.0",
    "typescript": "^5.6.0"
  }
}
