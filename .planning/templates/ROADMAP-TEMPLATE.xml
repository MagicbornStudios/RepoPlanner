<roadmap>
  <phase id="##">
    <goal>Goal description</goal>
    <requirements>REQ-XX</requirements>
    <depends>Previous phase id</depends>
    <status>planned|in-progress|complete</status>
    <links>
      <plan>path/to/.planning/phases/##-PLAN.xml</plan>
      <summary>path/to/.planning/phases/##-SUMMARY.xml</summary>
    </links>
  </phase>
  <doc-flow>
    <doc name="TASK-REGISTRY.xml">List tasks with keywords + statuses.</doc>
    <doc name="STATE.xml">Current phase pointer + next action.</doc>
    <doc name="LOOP-DOC-TEMPLATE.xml">Reference template for planning.</doc>
  </doc-flow>
</roadmap>
