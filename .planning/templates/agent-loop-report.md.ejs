| Phases (with tasks / total / complete) | <%= systemMetrics && systemMetrics.phasesWithTasks %> / <%= systemMetrics && systemMetrics.phasesTotal %> / <%= systemMetrics && systemMetrics.phasesComplete %> |
| Errors/attempts (ERRORS-AND-ATTEMPTS.xml) | <%= systemMetrics && systemMetrics.errorsAttemptsCount %> |
| Review (phases at 0% / unassigned / only planned) | <%= systemMetrics && systemMetrics.review ? systemMetrics.review.phasesAtZeroCount : 0 %> / <%= systemMetrics && systemMetrics.review ? systemMetrics.review.unassignedCount : 0 %> / <%= systemMetrics && systemMetrics.review ? systemMetrics.review.phasesOnlyPlannedCount : 0 %> |
